{
  "name": "empathy",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@8.15.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier -w .",
    "backend": "turbo run dev --filter=@empathy/api",
    "front": "turbo run dev --filter=@empathy/web",
    "dev": "turbo run dev --parallel --filter=@empathy/web --filter=@empathy/api"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.2.5",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "typescript": "^5.4.2",
    "@typescript-eslint/parser": "^8.43.0",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "ts-node": "^10.9.2",
    "turbo": "^2.2.3"
  },
  "workspaces": ["packages/*"],
  "lint-staged": {
    "*.{ts,tsx,js,jsx,svelte}": [
      "eslint --fix",
      "prettier -w"
    ],
    "*.{md,json,yml,yaml}": [
      "prettier -w"
    ]
  }
}
